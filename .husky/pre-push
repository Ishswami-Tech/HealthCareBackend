#!/bin/sh
# Pre-push hook for comprehensive validation
# Runs Prisma schema/migration guard + full build before pushing

echo "Running pre-push validation..."

# Block push if schema.prisma changed without migration changes in outgoing commits
yarn prisma:check-migration-sync || {
  echo ""
  echo "ERROR: Prisma schema/migration sync check failed."
  echo "If schema.prisma changed, commit migration files before pushing."
  exit 1
}

# Run full build - this ensures code builds successfully before pushing
# yarn build runs linting, formatting, type checking, security, compilation
yarn build || {
  echo ""
  echo "ERROR: Build failed. Fix errors before pushing."
  exit 1
}

echo ""
echo "Pre-push validation passed. Ready to push."
{
  "name": "healthcare-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "resolutions": {
    "@nestjs/core/path-to-regexp": "8.4.2",
    "@nestjs/platform-fastify/path-to-regexp": "8.4.2",
    "@nestjs/platform-fastify/fastify": "5.8.4",
    "detective-typescript/@typescript-eslint/typescript-estree": "8.58.0",
    "detective-typescript/@typescript-eslint/types": "8.58.0",
    "detective-typescript/@typescript-eslint/visitor-keys": "8.58.0",
    "@hono/node-server": "1.19.13",
    "hono": "4.12.12"
  },
  "scripts": {
    "build": "node scripts/build.js production",
    "build:dev": "node scripts/build.js development",
    "build:staging": "node scripts/build.js staging",
    "build:production": "node scripts/build.js production",
    "build:legacy": "yarn pre-build && nest build",
    "pre-build": "yarn validate:all",
    "validate:all": "yarn prisma:validate && yarn env:validate && yarn type-check && yarn lint:check && yarn security:audit && yarn format:check && yarn deps:check && yarn validate:code",
    "validate:build": "yarn validate:all && yarn build:test",
    "build:test": "tsc --noEmit --incremental false",
    "type-check": "tsc --noEmit",
    "lint": "yarn eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "lint:check": "yarn eslint \"{src,apps,libs}/**/*.ts\" --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "validate:code": "node scripts/validate-code.js",
    "validate:code:strict": "node scripts/validate-code.js --strict",
    "check:forbidden-comments": "node scripts/validate-code.js --forbidden-only",
    "security:audit": "audit-ci --moderate --config audit-ci.json",
    "security:fix": "node scripts/fix-vulnerabilities.js",
    "prisma:validate": "prisma format --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js --check",
    "env:validate": "ts-node -r tsconfig-paths/register scripts/validate-env.ts",
    "deps:check": "node scripts/check-deps.js",
    "deps:cycles": "node scripts/run-madge.js --circular",
    "deps:cycles:all": "madge --ts-config ./tsconfig.json --extensions ts --circular src",
    "deps:cycles:list": "node scripts/run-madge.js",
    "deps:graph": "node scripts/run-madge.js --image dependency-graph.svg",
    "outdated:check": "node scripts/validate-code.js --outdated-only",
    "todo:check": "node scripts/validate-code.js --todos-only",
    "pre-commit": "yarn validate:all",
    "pre-push": "yarn prisma:check-migration-sync && yarn build",
    "start": "cross-env NODE_ENV=development tsx -r tsconfig-paths/register src/main.ts",
    "start:dev": "cross-env NODE_ENV=development tsx watch -r tsconfig-paths/register src/main.ts",
    "start:dev:nodemon": "cross-env NODE_ENV=development nodemon",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "start:prod:cluster": "cross-env NODE_ENV=production ENABLE_CLUSTERING=true node dist/main.js",
    "prisma:generate": "prisma generate --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js && node scripts/fix-prisma.js && (yarn prettier --write \"src/libs/infrastructure/database/prisma/generated/**/*.ts\" 2>nul || echo \"[WARN] Prettier: No Prisma generated files found or already formatted\") || (echo \"[ERROR] Prisma generate failed!\" && exit 1)",
    "prisma:regenerate": "yarn prisma:generate && node scripts/validate-prisma-generated.js --regenerate",
    "prisma:validate-generated": "node scripts/validate-prisma-generated.js",
    "postinstall": "yarn prisma:generate || echo prisma-generate-skipped",
    "prepare": "husky || true",
    "prisma:db:push": "node scripts/run-prisma.js push",
    "prisma:migrate": "node scripts/run-prisma.js migrate",
    "prisma:check-migration-sync": "node scripts/validate-prisma-generated.js --check-migration-sync",
    "prisma:migrate:dev": "prisma migrate dev --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js",
    "prisma:studio": "prisma studio --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js",
    "prisma:format": "prisma format --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js",
    "prisma:reset": "prisma migrate reset --schema=./src/libs/infrastructure/database/prisma/schema.prisma --config=./src/libs/infrastructure/database/prisma/prisma.config.js --force",
    "seed:dev": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/libs/infrastructure/database/prisma/seed.ts",
    "seed:prod": "cross-env NODE_ENV=production node dist/libs/infrastructure/database/prisma/seed.js",
    "deploy:dev": "yarn prisma:generate && yarn prisma:migrate && yarn seed:dev",
    "deploy:prod": "yarn build && yarn prisma:generate && yarn prisma:migrate && yarn seed:prod",
    "docker:up": "cross-env NODE_ENV=development docker-compose -f devops/docker/docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f devops/docker/docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f devops/docker/docker-compose.dev.yml logs -f",
    "docker:rebuild": "docker-compose -f devops/docker/docker-compose.dev.yml down && cross-env NODE_ENV=development docker-compose -f devops/docker/docker-compose.dev.yml up -d --build",
    "docker:prod": "cross-env NODE_ENV=production docker-compose -f devops/docker/docker-compose.prod.yml up -d --build",
    "k8s:deploy": "powershell -ExecutionPolicy Bypass -File devops/kubernetes/scripts/deploy-local.ps1",
    "k8s:teardown": "powershell -ExecutionPolicy Bypass -File devops/kubernetes/scripts/teardown-local.ps1",
    "k8s:logs": "kubectl logs -f deployment/healthcare-api -n healthcare-backend",
    "k8s:status": "kubectl get pods,svc,deployments -n healthcare-backend",
    "health:check": "curl -f http://localhost:8088/health || echo 'Health check failed'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/client-ses": "^3.1023.0",
    "@aws-sdk/client-sns": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/fastify": "^6.20.6",
